<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{meta_title}}</title>
    {{ghost_head}}

    <style>
      body {
        margin: 0;
        padding: 24px;
        background: #fff;
        color: #000;
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 15px;
        line-height: 1.6;
      }

      .container {
        max-width: 720px;
        margin: 0 auto 64px auto;
      }

      .back {
        font-size: 12px;
        margin-bottom: 16px;
      }

      .back a {
        color: #000;
        text-decoration: none;
        border-bottom: 1px solid #000;
      }

      h1.post-title {
        font-size: 24px;
        margin: 0 0 8px 0;
      }

      .post-meta {
        font-size: 12px;
        color: #666;
        margin-bottom: 24px;
      }

      .post-content {
        font-size: 15px;
      }

      .post-content p {
        margin: 0 0 14px 0;
      }

      .post-content a {
        color: #000;
        text-decoration: underline;
      }
    </style>
</head>

<body>
  <div class="container">
    <div class="back">
      <a href="/texte/">← înapoi la texte</a>
    </div>

    <article class="post">
      <h1 class="post-title">{{title}}</h1>
      <div class="post-meta">
        {{date format="DD MMM YYYY"}}
      </div>

      <div class="post-content">
        {{content}}
      </div>
    </article>
  </div>

  {{ghost_foot}}
</body>
</html>