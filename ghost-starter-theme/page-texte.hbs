<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{meta_title}}</title>
    {{ghost_head}}

    <style>
      body {
        margin: 0;
        padding: 24px;
        background: #fff;
        color: #000;
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 14px;
        line-height: 1.55;
      }

      .container {
        max-width: 640px;
        margin: 0 auto;
      }

      h1 {
        font-size: 20px;
        margin-bottom: 24px;
      }

      .post-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .post-item a {
        text-decoration: none;
        color: #000;
        border-bottom: 1px solid #000;
        padding-bottom: 3px;
        transition: opacity .15s;
      }

      .post-item a:hover {
        opacity: 0.6;
      }

      .post-date {
        color: #666;
        font-size: 12px;
        margin-top: 4px;
      }
    </style>
</head>

<body>
  <div class="container">
    <h1>texte</h1>

    <div class="post-list">
      {{#foreach posts}}
        <div class="post-item">
          <a href="{{url}}">{{title}}</a>
          <div class="post-date">{{date format="DD MMM YYYY"}}</div>
        </div>
      {{/foreach}}
    </div>
  </div>

  {{ghost_foot}}
</body>
</html>