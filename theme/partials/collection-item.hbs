<article class="collection-item {{#if feature_image}}has-thumb{{else}}no-thumb{{/if}} {{post_class}}">
  {{#if feature_image}}
    <a class="collection-item__thumb" href="{{url}}" aria-label="{{title}}">
      <img src="{{img_url feature_image size="s"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    </a>
  {{/if}}

  <div class="collection-item__body">
    <div class="collection-item__meta">
      <time datetime="{{date format="YYYY-MM-DD"}}">{{#has tag="isnan"}}2026{{else}}{{date format="D MMM YYYY"}}{{/has}}</time>
      {{#if primary_tag}}
        <span>{{primary_tag.name}}</span>
      {{/if}}
    </div>

    <h2 class="collection-item__title">
      <a href="{{url}}">{{title}}</a>
    </h2>

    {{#if excerpt}}
      <p class="collection-item__excerpt">{{excerpt words="30"}}</p>
    {{/if}}
  </div>
</article>
