<!doctype html>
<html lang="ro">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{meta_title}}</title>
  {{ghost_head}}

  <style>
    :root{
      --bg:#ffffff;
      --surface:#ffffff;
      --ink:#111111;
      --muted:rgba(0,0,0,.62);
      --hairline:rgba(0,0,0,.10);
      --soft:rgba(0,0,0,.06);

      --font-body: var(--font-mono);
      --font-mono: 'Inconsolata', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;

      --radius: 16px;
      --page: 1120px;
      --text: 760px;
      --makoff-announcement-height: 44px;
    }

    *{box-sizing:border-box}
    html, body{height:100%}

    body{
      margin:0;
      background:var(--bg);
      color:var(--ink);
      font-family:var(--font-body);
      -webkit-font-smoothing:antialiased;
      text-rendering:optimizeLegibility;
    }

    a{color:inherit}

    /* --- Site shell --- */
    .site{
      min-height:100vh;
      display:flex;
      flex-direction:column;
    }

    .makoff-announcement{
      position:sticky;
      top:0;
      z-index:100;
      min-height:var(--makoff-announcement-height);
      display:grid;
      grid-template-columns:minmax(36px, 1fr) auto minmax(36px, 1fr);
      align-items:center;
      gap:12px;
      padding:7px 16px;
      background:#ec3b78;
      color:#fff;
      border-bottom:1px solid rgba(0,0,0,.12);
      font-family:var(--font-mono);
      font-size:13px;
      line-height:1.25;
    }

    .makoff-announcement[hidden]{display:none}

    .makoff-announcement__link{
      grid-column:2;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:12px;
      min-width:0;
      color:inherit;
      text-align:center;
      text-decoration:none;
      white-space:nowrap;
    }

    .makoff-announcement__text{
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .makoff-announcement__button{
      display:inline-flex;
      align-items:center;
      min-height:28px;
      padding:0 12px;
      border:1px solid #111;
      border-radius:999px;
      background:#111;
      color:#fff;
      font-weight:700;
      line-height:1;
    }

    .makoff-announcement__close{
      grid-column:3;
      justify-self:end;
      width:32px;
      height:32px;
      padding:0;
      border:0;
      border-radius:999px;
      background:transparent;
      color:#fff;
      cursor:pointer;
      font:inherit;
      font-size:24px;
      line-height:1;
    }

    .makoff-announcement__close:hover{background:rgba(255,255,255,.16)}

    .site-header{
      position:sticky;
      top:var(--makoff-announcement-height, 0px);
      z-index:50;
      background:rgba(255,255,255,.88);
      backdrop-filter:saturate(180%) blur(10px);
      border-bottom:1px solid var(--hairline);
    }

    .site-header__inner{
      max-width:var(--page);
      margin:0 auto;
      padding:14px 18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
    }

    .brand{
      display:flex;
      align-items:baseline;
      gap:10px;
      min-width:0;
      text-decoration:none;
    }

    .brand__name{
      font-weight:700;
      letter-spacing:.2px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .brand__tag{
      font-family:var(--font-mono);
      font-size:12px;
      opacity:.6;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .nav{
      display:flex;
      align-items:center;
      gap:16px;
      flex-wrap:wrap;
    }

    .nav ul{
      list-style:none;
      margin:0;
      padding:0;
      display:flex;
      align-items:center;
      gap:16px;
      flex-wrap:wrap;
    }

    .nav li{margin:0; padding:0}

    .nav a{
      text-decoration:none;
      font-family:var(--font-mono);
      font-size:12px;
      letter-spacing:.2px;
      opacity:.85;
      padding:6px 8px;
      border-radius:10px;
    }

    .nav a:hover{background:var(--soft); opacity:1}

    .nav .nav__link--outline{
      border:1px solid rgba(0,0,0,.55);
      background:transparent;
      opacity:1;
    }
    .nav .nav__link--outline:hover{background:var(--soft)}

    .nav .nav__link--cta{
      border:1px solid #111;
      background:#111;
      color:#fff;
      opacity:1;
    }

    .nav .nav__link--cta:hover{background:#000}

    .site-main{
      flex:1;
      max-width:var(--page);
      margin:0 auto;
      padding:28px 18px 64px;
      width:100%;
    }

    .site-footer{
      border-top:1px solid var(--hairline);
      background:var(--surface);
    }

    .site-footer__inner{
      max-width:var(--page);
      margin:0 auto;
      padding:22px 18px;
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      color:var(--muted);
      font-family:var(--font-mono);
      font-size:12px;
    }

    .site-footer a{color:inherit; text-decoration:none}
    .site-footer a:hover{text-decoration:underline}

    /* --- Page wrappers used by your templates --- */
    .gh-page{width:100%}
    .gh-container{width:100%; max-width:var(--page); margin:0 auto}
    .gh-canvas{max-width:var(--text); margin:0 auto}

    /* --- Headings / long-form readability --- */
    .gh-title{
      font-size:44px;
      line-height:1.08;
      letter-spacing:-.02em;
      margin:0 0 10px;
    }

    .gh-excerpt{
      margin:0;
      font-size:18px;
      line-height:1.6;
      color:var(--muted);
      max-width:66ch;
    }

    .gh-content{
      font-size:18px;
      line-height:1.75;
      margin-top:18px;
    }

    .gh-content p{margin:0 0 1.05em}
    .gh-content h2{font-size:26px; line-height:1.2; margin:1.6em 0 .6em}
    .gh-content h3{font-size:20px; line-height:1.25; margin:1.4em 0 .5em}
    .gh-content hr{border:0; border-top:1px solid var(--hairline); margin:28px 0}

    .gh-content blockquote{
      margin:1.2em 0;
      padding:0.1em 0 0.1em 1em;
      border-left:3px solid rgba(0,0,0,.18);
      color:rgba(0,0,0,.78);
    }

    .gh-content a{ text-decoration:underline; text-decoration-thickness:1px; text-underline-offset:2px; }
    .gh-content a:hover{ text-decoration-thickness:2px; }

    /* media never overflow */
    img, video{max-width:100%; height:auto}
    figure{margin:1.2em 0}
    .kg-width-wide, .kg-width-full{max-width:100%}

    /* --- Post meta --- */
    .post-meta, .gh-card-meta{
      font-family:var(--font-mono);
      font-size:12px;
      color:var(--muted);
    }

    /* --- Feed/cards --- */
    .gh-postfeed{max-width:var(--text); margin:0 auto}

    .gh-card{
      border-top:1px solid var(--hairline);
      padding:18px 0;
    }

    .gh-card:first-child{border-top:none; padding-top:0}

    .gh-card-link{
      display:grid;
      grid-template-columns: 148px 1fr;
      gap:18px;
      text-decoration:none;
      align-items:start;
    }

    .gh-card-picture, .gh-card-image{width:148px}
    .gh-card-image{border-radius:14px}

    .gh-card-content{min-width:0}
    .gh-card-title{margin:6px 0 8px; font-size:18px; line-height:1.25}
    .gh-card-content p{margin:0; color:rgba(0,0,0,.78); line-height:1.55}
    .gh-card-content strong{display:none}

    @media (max-width: 840px){
      .gh-title{font-size:36px}
      .gh-content{font-size:17px}
      .gh-card-link{grid-template-columns: 120px 1fr}
      .gh-card-picture, .gh-card-image{width:120px}
    }

    @media (max-width: 560px){
      :root{--makoff-announcement-height:52px;}
      .makoff-announcement{
        grid-template-columns:1fr 32px;
        padding:8px 10px 8px 14px;
        font-size:12px;
      }
      .makoff-announcement__link{
        grid-column:1;
        justify-content:flex-start;
        gap:8px;
        white-space:normal;
      }
      .makoff-announcement__button{min-height:26px; padding:0 10px;}
      .makoff-announcement__close{grid-column:2;}
      .site-header__inner{padding:12px 14px}
      .brand__tag{display:none}
      .site-main{padding:22px 14px 52px}
      .gh-title{font-size:32px}
      .gh-card-link{grid-template-columns: 1fr}
      .gh-card-picture, .gh-card-image{width:100%}
    }
  </style>
  <link rel="stylesheet" href="{{asset "css/typography-patch.css"}}">
</head>
<body class="{{body_class}}">
  <div class="site">
    <div class="makoff-announcement" data-makoff-announcement>
      <a class="makoff-announcement__link" href="https://www.makoff.ro/#/portal/signup" onclick="window.location.href=(window.location.origin + '/#/portal/signup'); return false;">
        <span class="makoff-announcement__text">sprijină scrisul și gândirea critică prin</span>
        <span class="makoff-announcement__button">makonat</span>
      </a>
      <button class="makoff-announcement__close" type="button" aria-label="închide" data-makoff-announcement-close>×</button>
    </div>

    {{> "site-header"}}

    <main class="site-main">
      {{{body}}}
    </main>

    {{> "site-footer"}}
  </div>

  {{ghost_foot}}
  <script src="{{asset "js/portal-hooks.js"}}"></script>
  <script>
    (function () {
      var root = document.documentElement;
      var bar = document.querySelector("[data-makoff-announcement]");
      var close = document.querySelector("[data-makoff-announcement-close]");
      var key = "makoff-announcement-2026-04-critic-closed";

      function hideAnnouncement() {
        if (!bar) {
          return;
        }
        bar.hidden = true;
        root.style.setProperty("--makoff-announcement-height", "0px");
      }

      try {
        if (window.localStorage.getItem(key) === "1") {
          hideAnnouncement();
        }
      } catch (error) {}

      if (close) {
        close.addEventListener("click", function () {
          hideAnnouncement();
          try {
            window.localStorage.setItem(key, "1");
          } catch (error) {}
        });
      }
    })();
  </script>
</body>
</html>
