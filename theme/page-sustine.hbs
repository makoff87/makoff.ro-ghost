<style>
  .support-shell{
    position:relative;
    width:100%;
    height:100vh;
    padding:18px 14px;
    padding-top:34px;
    padding-bottom:26px;
    font-family: var(--font-mono);
    font-size:12px;
    line-height:1.45;
  }
  .support-desktop{position:relative;width:100%;height:100%}
  .folder{
    position:absolute;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:6px;
    width:110px;
    text-align:center;
    text-decoration:none;
    color:inherit;
    user-select:none;
  }
  .folder .emoji{font-size:3rem; line-height:1; transition:transform .08s ease}
  .folder:hover .emoji{transform:translateY(-2px)}
  .folder .label{font-size:12px; opacity:.9}

  /* BT panel */
  #bt-panel{
    position:fixed;
    left:50%;
    top:50%;
    transform:translate(-50%,-50%);
    width:min(520px, calc(100vw - 32px));
    background:var(--surface);
    border:1px solid var(--hairline);
    box-shadow:0 12px 40px rgba(0,0,0,.14);
    border-radius:10px;
    padding:14px 14px 12px;
    display:none;
    z-index:100;
  }
  #bt-panel.is-open{display:block}
  #bt-panel .row{display:flex; align-items:flex-start; justify-content:space-between; gap:12px}
  #bt-panel h2{font-size:13px; margin:0 0 10px; font-weight:600}
  #bt-panel pre{
    margin:0;
    padding:10px 10px;
    background:rgba(0,0,0,.04);
    border:1px solid var(--hairline);
    border-radius:8px;
    white-space:pre-wrap;
    word-break:break-word;
  }
  #bt-panel .actions{display:flex; gap:8px; margin-top:10px}
  #bt-panel .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:6px 10px;
    border-radius:8px;
    border:1px solid var(--hairline);
    background:var(--surface);
    cursor:pointer;
    font-family:inherit;
    font-size:12px;
    text-decoration:none;
    color:inherit;
  }
  #bt-panel .btn:hover{background:rgba(0,0,0,.03)}
  #bt-panel .close{border-color:transparent; background:transparent; opacity:.7}
  #bt-panel .close:hover{opacity:1}
</style>

